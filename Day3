#include <stdio.h>
#define MAX 100

int queue[MAX];
int front = -1, rear = -1;

int vis[MAX];          // visited array
int graph[MAX][MAX];   // adjacency matrix

// Function to insert into queue
void add(int item)
{
    if (rear == MAX - 1)
    {
        printf("Queue Overflow\n");
        return;
    }

    if (front == -1)
        front = 0;

    rear++;
    queue[rear] = item;
}

// Function to delete from queue
int delete()
{
    int item;

    if (front == -1 || front > rear)
        return 0;   // queue empty

    item = queue[front];
    front++;

    return item;
}

// BFS function
void bfs(int s, int n)
{
    int p, i;

    add(s);
    vis[s] = 1;

    p = delete();

    while (p != 0)
    {
        printf("%d ", p);

        for (i = 1; i <= n; i++)
        {
            if (graph[p][i] == 1 && vis[i] == 0)
            {
                add(i);
                vis[i] = 1;
            }
        }

        p = delete();
    }
}

// Main function
int main()
{
    int n, i, j, start;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for (i = 1; i <= n; i++)
    {
        for (j = 1; j <= n; j++)
        {
            scanf("%d", &graph[i][j]);
        }
    }

    // Initialize visited array
    for (i = 1; i <= n; i++)
        vis[i] = 0;

    printf("Enter starting node: ");
    scanf("%d", &start);

    printf("BFS Traversal: ");
    bfs(start, n);

    return 0;
}
