#include <stdio.h>

void knapsack(int m, int n, float p[], float w[], float x[])
{
    int i;
    float U;

    // initialize x[]
    for(i = 0; i < n; i++)
        x[i] = 0.0;

    U = m;

    // Fill objects completely if possible
    for(i = 0; i < n; i++)
    {
        if(w[i] > U)
            break;
        else
        {
            x[i] = 1.0;
            U = U - w[i];
        }
    }

    // Take fraction of next object
    if(i < n)
        x[i] = U / w[i];
}

int main()
{
    int n = 3, m = 50;
    float p[3] = {60, 100, 120};
    float w[3] = {10, 20, 30};
    float x[3];

    knapsack(m, n, p, w, x);

    printf("Solution vector:\n");
    for(int i = 0; i < n; i++)
        printf("%.2f ", x[i]);

    // Calculate maximum profit
    float profit = 0.0;
    for(int i = 0; i < n; i++)
        profit += x[i] * p[i];

    printf("\nMaximum Profit = %.2f", profit);

    return 0;
}
